#!/usr/bin/env bash
# Create a new worktrunk branch in mono and let the post-switch hook
# (wt-zellij-tab) spawn the Zellij tab with the worktree layout.

[ -z "$ZELLIJ" ] && echo "Not inside Zellij" && exit 1

# Use fzf as a text-input prompt so Esc cleanly aborts the floating pane.
# Enter prints the typed query and aborts; Esc aborts with no output.
name=$(fzf \
    --prompt="branch name> " \
    --header="enter: create  esc: cancel" \
    --bind="enter:print-query+abort" \
    < /dev/null 2>/dev/null | xargs)

[ -z "$name" ] && exit 0

wt -C "$HOME/code/mono/master" switch --create "$name"
