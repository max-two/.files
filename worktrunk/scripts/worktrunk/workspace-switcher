#!/usr/bin/env bash
# Unified workspace switcher for Zellij + worktrunk.
# Shows all Zellij tabs and all worktrees across repos in a single fzf picker.
#
# Entry types:
#   [tab]  — plain Zellij tab (no worktree)
#   [wt]   — worktree with an active Zellij tab
#   [wt+]  — worktree that exists but has no tab open
#   [repo] — regular repo with no tab open
#
# Keybinds:
#   enter  — switch to tab (creates tab for [wt+] entries)
#   ctrl-d — close tab / remove worktree

dry_run=false
for arg in "$@"; do
    case "$arg" in
        --dry-run) dry_run=true ;;
    esac
done

[ "$dry_run" = false ] && [ -z "$ZELLIJ" ] && echo "Not inside Zellij" && exit 1

# --- Gather data ---

# Get all Zellij tab names (one per line)
tabs=$(zellij action query-tab-names 2>/dev/null)

# --- Scan ~/code/ and build fzf entries in one pass ---
# Format: "label  display_name\tmetadata"
# metadata is hidden from display but available to the action handler

wt_entries=""
repo_entries=""
tab_entries=""
declare -A known_tab_names
shopt -s dotglob

for dir in ~/code/*/; do
    repo=$(basename "$dir")

    if [ -f "$dir/.git" ] && grep -q "gitdir.*bare" "$dir/.git" 2>/dev/null; then
        # Bare repo — find a worktree to run git from, then list all worktrees
        wt_dir=""
        for sub in "$dir"*/; do
            [ -f "$sub/.git" ] 2>/dev/null || [ -d "$sub/.git" ] 2>/dev/null || continue
            wt_dir="$sub"
            break
        done
        [ -z "$wt_dir" ] && continue

        current_path=""
        while IFS= read -r line; do
            case "$line" in
                "worktree "*)
                    current_path="${line#worktree }"
                    ;;
                "branch "*)
                    branch="${line#branch refs/heads/}"
                    tab_name="$repo / $(echo "$branch" | tr '/\\' '--')"
                    known_tab_names["$tab_name"]=1
                    if echo "$tabs" | grep -qxF "$tab_name"; then
                        wt_entries+="[wt]  $tab_name"$'\t'"wt:$tab_name:$current_path"$'\n'
                    else
                        wt_entries+="[wt+] $tab_name"$'\t'"wt+:$tab_name:$current_path"$'\n'
                    fi
                    ;;
                bare)
                    current_path=""
                    ;;
            esac
        done < <(git -C "$wt_dir" worktree list --porcelain 2>/dev/null)

    elif [ -d "$dir/.git" ]; then
        # Regular repo
        known_tab_names["$repo"]=1
        if echo "$tabs" | grep -qxF "$repo"; then
            tab_entries+="[tab] $repo"$'\t'"tab:$repo:"$'\n'
        else
            repo_entries+="[repo] $repo"$'\t'"repo:$repo:$dir"$'\n'
        fi
    fi
done

# Add remaining tabs that don't match any repo or worktree
while IFS= read -r tab; do
    [ -z "$tab" ] && continue
    if [ -z "${known_tab_names[$tab]+x}" ]; then
        tab_entries+="[tab] $tab"$'\t'"tab:$tab:"$'\n'
    fi
done <<< "$tabs"

entries="${wt_entries}${repo_entries}${tab_entries}"
[ -z "$entries" ] && echo "No tabs or worktrees found" && exit 0

if [ "$dry_run" = true ]; then
    echo -n "$entries" | while IFS=$'\t' read -r display meta; do
        printf '%s\t%s\n' "$display" "$meta"
    done
    exit 0
fi

# --- Run fzf ---

selection=$(echo -n "$entries" | fzf \
    --ansi \
    --no-multi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --prompt="workspace> " \
    --header="enter: switch  ctrl-d: close/remove" \
    --bind="ctrl-d:execute-silent(echo {2} > $TMPDIR/ws-switcher-delete)+abort" \
    --expect=enter \
)

# Handle ctrl-d (delete)
if [ -f "$TMPDIR/ws-switcher-delete" ]; then
    delete_meta=$(cat "$TMPDIR/ws-switcher-delete")
    rm -f "$TMPDIR/ws-switcher-delete"

    IFS=: read -r type name path <<< "$delete_meta"
    case "$type" in
        tab)
            # Can't close tabs via CLI easily — just inform
            echo "Tab close not yet supported via Zellij CLI"
            ;;
        wt|wt+)
            # Remove the worktree and close the tab if open
            if [ -n "$path" ]; then
                branch=$(git -C "$path" branch --show-current 2>/dev/null)
                repo_bare=$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/\.bare$||')
                # Find any worktree in the repo to run wt from
                for sub in "$repo_bare"/*/; do
                    [ "$sub" = "$path/" ] && continue
                    [ -f "$sub/.git" ] 2>/dev/null || [ -d "$sub/.git" ] 2>/dev/null || continue
                    wt -C "$sub" remove "$branch" 2>/dev/null
                    break
                done
            fi
            ;;
    esac
    exit 0
fi

# Handle enter (switch)
# fzf --expect outputs the key on line 1, the selection on line 2
key=$(echo "$selection" | sed -n '1p')
chosen=$(echo "$selection" | sed -n '2p')
[ -z "$chosen" ] && exit 0

meta=$(echo "$chosen" | cut -f2)
IFS=: read -r type name path <<< "$meta"

on_startup=false
echo "$tabs" | grep -qxF "__startup__" && on_startup=true

case "$type" in
    tab|wt)
        zellij action go-to-tab-name "$name"
        ;;
    wt+|repo)
        zellij action new-tab --layout worktree --name "$name" --cwd "$path"
        ;;
esac

# Clean up the startup tab if it exists
if [ "$on_startup" = true ]; then
    zellij action go-to-tab-name "__startup__" 2>/dev/null
    zellij action close-tab 2>/dev/null
fi
