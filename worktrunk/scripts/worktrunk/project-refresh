#!/usr/bin/env bash
# Restart the configured AI in the current pane, resuming the previous session.
# Runs in-place in the AI pane (Alt+z keybind with in_place=true). The old AI is
# suspended by Zellij; exec replaces this script with the new process in the
# same pane position.
#
# in_place stacks suspended panes that can never regain focus, so
# zellij-attention notifications set against them persist forever (the
# plugin clears only on focus). Before exec we close any suspended
# panes at our tab position to prevent stuck notification icons.

set -euo pipefail

# Close suppressed (suspended) panes left by previous in_place replacements.
# Each Alt+z suspends the current pane and creates a new one on top; those
# ghosts hold stale zellij-attention notifications that can never be cleared
# by focus. Closing them removes the pane IDs from Zellij's manifest so the
# plugin's stale-notification cleanup drops them.
zellij action list-panes --state --tab --json 2>/dev/null \
    | jq -r --argjson self "${ZELLIJ_PANE_ID:-0}" '
        (.[] | select(.id == $self) | .tab_id) as $tab |
        .[] | select(.is_suppressed and (.is_plugin | not) and .tab_id == $tab)
        | "terminal_\(.id)"' \
    | while IFS= read -r pid; do
        zellij action focus-pane-id "$pid" 2>/dev/null || true
        zellij action close-pane --pane-id "$pid" 2>/dev/null || true
    done
zellij action focus-pane-id "terminal_${ZELLIJ_PANE_ID}" 2>/dev/null || true

exec ai-panel --continue
