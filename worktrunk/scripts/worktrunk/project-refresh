#!/usr/bin/env bash
# Restart Claude with a new MCP selection, resuming the previous session.
# Runs in-place in the Claude pane (Alt+z keybind with in_place=true).
# The old Claude is suspended by Zellij; exec replaces this script with
# the new Claude process in the same pane position.

set -euo pipefail

template="$HOME/.claude/mcp-servers.json"
[ -f "$template" ] || { echo "No MCP template at $template"; sleep 2; exit 1; }

script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")
enabled=$("$script_dir/mcp-picker") || exit 0

keys_json=$(printf '%s' "$enabled" | tr ' ' '\n' | jq -R 'select(length > 0)' | jq -s .)
mcp_file="${TMPDIR:-/tmp}/claude-mcp-$$.json"
jq -c --argjson keys "$keys_json" \
    '{mcpServers: (.mcpServers | to_entries | map(select(.key as $k | $keys | index($k))) | from_entries)}' \
    "$template" > "$mcp_file"

exec claude --strict-mcp-config --mcp-config "$mcp_file" --continue
