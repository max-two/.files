#!/usr/bin/env bash
# Create or focus a Zellij tab for the project at <path>.
# Tab name is looked up from project-list, which is the source of truth for
# how every known path is named.
# Usage: zellij-tab-open <path>
#
# If WT_CLAUDE_PROMPT is set in the environment when a NEW tab is created, the
# tab is opened from a copy of the `layout` layout with that prompt injected
# as an argument to the `claude` pane (so Claude starts already working on
# it). This is how the Linear integration (linear-work) seeds a worktree's
# Claude session. The manual Alt+n flow leaves the var unset and is
# unaffected, as is re-opening (focusing) an existing tab.

[ -z "${ZELLIJ:-}" ] && exit 0

path="$1"
script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")

name=$("$script_dir/project-list" | awk -F'\t' -v p="$path" '$2 == p { print $1; exit }')
[ -z "$name" ] && name=$(basename "$path")

# Locate the on-disk `layout` layout so we can build a modified copy.
# In the headless Linear path the ZELLIJ_CONFIG_* vars aren't set, so fall
# back to the stowed location.
resolve_layout_file() {
    if [ -n "${ZELLIJ_CONFIG_DIR:-}" ] && [ -f "$ZELLIJ_CONFIG_DIR/layouts/layout.kdl" ]; then
        printf '%s' "$ZELLIJ_CONFIG_DIR/layouts/layout.kdl"
        return 0
    fi
    if [ -n "${ZELLIJ_CONFIG_FILE:-}" ]; then
        local f="$(dirname "$ZELLIJ_CONFIG_FILE")/layouts/layout.kdl"
        [ -f "$f" ] && { printf '%s' "$f"; return 0; }
    fi
    [ -f "$HOME/.config/zellij/layouts/layout.kdl" ] \
        && { printf '%s' "$HOME/.config/zellij/layouts/layout.kdl"; return 0; }
    return 1
}

# Build a KDL raw string fence long enough for the given text.
kdl_fence() {
    local maxrun
    maxrun=$(printf '%s' "$1" | grep -oE '#+' | awk '{ if (length > m) m = length } END { print m + 0 }')
    printf '%*s' "$((maxrun + 1))" '' | tr ' ' '#'
}

# Emit the `layout` KDL with extra args injected into the claude pane.
# Uses WT_CLAUDE_PROMPT (and WT_CLAUDE_CONTINUE, if set) from the environment.
build_layout_with_args() {
    local file="$1"
    local args_line=""

    if [ -n "${WT_CLAUDE_PROMPT:-}" ]; then
        local prompt_fence
        prompt_fence=$(kdl_fence "$WT_CLAUDE_PROMPT")
        args_line="r${prompt_fence}\"${WT_CLAUDE_PROMPT}\"${prompt_fence}"
    fi

    if [ -n "${WT_CLAUDE_CONTINUE:-}" ]; then
        args_line="${args_line:+$args_line }\"--continue\""
    fi

    [ -z "$args_line" ] && { cat "$file"; return; }

    ARGS_LINE="$args_line" awk '
        !injected && /command="claude"/ {
            printf "%s {\n", $0
            printf "            args %s\n", ENVIRON["ARGS_LINE"]
            printf "        }\n"
            injected = 1
            next
        }
        { print }
    ' "$file"
}

# Focus an existing tab for this path if one is open. worktree-tab-id resolves
# it live by pane CWD — NOT by tab name, which may still be the interim fallback
# while worktree-tab-namer renames it asynchronously (a name match could miss it
# and open a duplicate).
existing_tab_id=$("$script_dir/worktree-tab-id" "$path" | head -n1)

if [ -n "$existing_tab_id" ]; then
    zellij action go-to-tab-by-id "$existing_tab_id"
    exit 0
fi

# new-tab prints the created tab's id on stdout — capture it so we can hand it
# straight to the namer below, instead of having the namer re-discover the tab
# at rename time.
if [ -n "${WT_CLAUDE_PROMPT:-}" ] && layout_file=$(resolve_layout_file); then
    new_tab_id=$(zellij action new-tab \
        --layout-string "$(build_layout_with_args "$layout_file")" \
        --name "$name" --cwd "$path")
else
    new_tab_id=$(zellij action new-tab --layout layout --name "$name" --cwd "$path")
fi

# Upgrade the tab name to a short, meaningful AI-generated label in the
# background (~10s, then cached forever for this worktree). Detached so it
# outlives this hook invocation; no-ops for non-worktrees / already-cached
# paths. Pass the id of the tab we just created so the rename targets it
# directly — no runtime tab lookup, no race. See worktree-tab-namer.
nohup "$script_dir/worktree-tab-namer" "$path" "$new_tab_id" >/dev/null 2>&1 &
