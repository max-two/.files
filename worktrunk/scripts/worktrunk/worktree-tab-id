#!/usr/bin/env bash
# Resolve the live Zellij tab(s) for a worktree by matching pane CWDs — the
# single source of truth for "which tab belongs to this worktree path", shared
# by zellij-tab-open (focus), zellij-tab-close (close), and worktree-tab-namer
# (rename).
#
# We match on pane CWD, deliberately NOT on:
#   - tab name: labels are AI-generated and renamed asynchronously, so a name
#     match could miss a tab still showing its interim fallback label; and
#   - a persisted tab id: zellij owns tab lifecycle and gives us no events to
#     invalidate a cached id, so it could silently point at the wrong tab.
#     Re-validating a cached id would mean querying live state anyway — the same
#     cost as just resolving it fresh here.
#
# Prints the unique matching tab IDs, one per line (empty if none). Callers that
# want a single tab take the first line; zellij-tab-close acts on all of them.
#
# The match requires the pane CWD to equal <path> or sit under "<path>/", so
# /code/mono/foo never matches /code/mono/foo-bar.
#
# Usage: worktree-tab-id <path>

set -uo pipefail

path="${1:-}"
[ -n "$path" ] || exit 0

zellij action list-panes --json 2>/dev/null \
    | jq -r --arg p "$path" '
        ($p + "/") as $prefix |
        [.[] | select(.is_plugin == false and ((.pane_cwd // "") as $cwd | $cwd == $p or ($cwd | startswith($prefix))))]
        | [.[].tab_id] | unique | .[]
    ' 2>/dev/null
