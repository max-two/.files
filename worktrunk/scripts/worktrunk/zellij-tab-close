#!/usr/bin/env bash
# Close the Zellij tab for the project at <path>. Called from post-remove,
# so the path may no longer exist — derive the tab name from path components.
# Usage: zellij-tab-close <path>

[ -z "${ZELLIJ:-}" ] && exit 0

path="$1"
parent=$(dirname "$path")

# For bare-repo worktrees, the basename of the worktree directory IS the
# sanitized branch name (worktrunk's worktree-path template uses
# `{{ branch | sanitize }}` for the leaf). So we can construct the tab
# name without invoking git on a path that may already be gone.
name="$(basename "$parent") / $(basename "$path")"

# If the user is currently on the target tab, close-tab-by-id can be
# unreliable. Use plain close-tab for that case (closes the focused tab).
# For any other tab, use close-tab-by-id so the user's focus doesn't move.
current_name=$(zellij action current-tab-info --json 2>/dev/null \
    | jq -r '.name // empty' 2>/dev/null)

if [ "$current_name" = "$name" ]; then
    zellij action close-tab
else
    target_id=$(zellij action list-tabs --json 2>/dev/null \
        | jq -r --arg n "$name" '.[] | select(.name == $n) | .tab_id' 2>/dev/null \
        | head -1)
    [ -n "$target_id" ] && zellij action close-tab-by-id "$target_id"
fi
