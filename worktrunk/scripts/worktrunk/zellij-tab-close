#!/usr/bin/env bash
# Close all Zellij tabs whose panes have CWDs at or under <path>. Called from
# post-remove — the worktree may already be gone, but pane CWDs still reflect
# the path they were launched with.
# Usage: zellij-tab-close <path>

[ -z "${ZELLIJ:-}" ] && exit 0

path="$1"

# Collect unique tab IDs that have panes rooted at this worktree.
# Match requires exact path or path + "/" prefix to avoid collisions
# (e.g. /code/mono/foo must not match /code/mono/foo-bar).
tab_ids=$(zellij action list-panes --json 2>/dev/null \
    | jq -r --arg p "$path" '
        ($p + "/") as $prefix |
        [.[] | select(.is_plugin == false and ((.pane_cwd // "") as $cwd | $cwd == $p or ($cwd | startswith($prefix))))]
        | [.[].tab_id] | unique | .[]
    ' 2>/dev/null)

[ -z "$tab_ids" ] && exit 0

current_id=$(zellij action current-tab-info --json 2>/dev/null \
    | jq -r '.tab_id // empty' 2>/dev/null)

# Close non-focused tabs first by ID, then close the focused tab last
# (close-tab-by-id is unreliable for the focused tab).
close_current=false
while IFS= read -r tid; do
    [ -z "$tid" ] && continue
    if [ "$tid" = "$current_id" ]; then
        close_current=true
    else
        zellij action close-tab-by-id "$tid"
    fi
done <<< "$tab_ids"

[ "$close_current" = true ] && zellij action close-tab
