#!/usr/bin/env bash
# Enumerate projects from ~/code/* and ~/scripts/*, plus any extra paths
# listed in ~/.config/projects.conf (one path per line, # for comments).
# Output: TSV with columns: name, path, type
#   type=worktree  bare-repo worktree, or additional worktree of a regular repo
#   type=repo      main worktree of a regular repo (path matches ~/code/<repo>)
#   type=path      single path from ~/.config/projects.conf (need not be a git repo)

set -euo pipefail
shopt -s nullglob dotglob

script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")

# Preload AI-generated tab-name labels (worktree path -> label) via worktree-name,
# which owns the cache location and format. A missing cache is fine — flush()
# falls back to the label derived from the branch. Last line wins.
declare -A TAB_NAME_CACHE=()
while IFS=$'\t' read -r cpath clabel || [ -n "$cpath" ]; do
    [ -n "$cpath" ] && TAB_NAME_CACHE["$cpath"]="$clabel"
done < <("$script_dir/worktree-name" dump)

emit_worktrees() {
    local repo="$1" repo_dir="$2"
    local current_path="" branch="" is_bare=0 in_entry=0

    flush() {
        [ "$in_entry" = 1 ] || return 0
        [ "$is_bare" = 1 ] && return 0
        local name type
        local sanitized
        sanitized=$(printf '%s' "$branch" | tr '/\\' '--')
        # Strip Linear's "<username>-<team>-" prefix (noise — the repo name and
        # ticket number are enough), keeping <number>-<title>. Non-Linear branches
        # not matching <word>-<letters>-<digits>-... are left untouched.
        [[ "$sanitized" =~ ^[A-Za-z0-9]+-[A-Za-z]+-([0-9]+-.+)$ ]] && sanitized="${BASH_REMATCH[1]}"
        # Prefer an AI-generated label (worktree-tab-namer) when one is cached
        # for this worktree; otherwise use the derived branch portion.
        [ -n "${TAB_NAME_CACHE["$current_path"]:-}" ] && sanitized="${TAB_NAME_CACHE["$current_path"]}"
        # length-limit the branch portion shown in the tab name
        [ "${#sanitized}" -gt 25 ] && sanitized="${sanitized:0:25}"
        if [ "$current_path" = "$repo_dir" ] && [ -d "$repo_dir/.git" ]; then
            name="$repo"
            type="repo"
        else
            name="${repo}┃${sanitized}"
            type="worktree"
        fi
        printf '%s\t%s\t%s\n' "$name" "$current_path" "$type"
    }

    while IFS= read -r line; do
        case "$line" in
            "worktree "*)
                flush
                current_path="${line#worktree }"
                branch=""
                is_bare=0
                in_entry=1
                ;;
            "branch "*)
                branch="${line#branch refs/heads/}"
                ;;
            bare)
                is_bare=1
                ;;
            detached)
                branch="detached"
                ;;
        esac
    done < <(git -C "$repo_dir" worktree list --porcelain 2>/dev/null)
    flush
}

for root in "$HOME/code" "$HOME/scripts"; do
    [ -d "$root" ] || continue
    for dir in "$root"/*/; do
        dir="${dir%/}"
        repo=$(basename "$dir")

        if [ -f "$dir/.git" ] && grep -q "gitdir.*bare" "$dir/.git" 2>/dev/null; then
            emit_worktrees "$repo" "$dir"
        elif [ -d "$dir/.git" ]; then
            emit_worktrees "$repo" "$dir"
        fi
    done
done

config="${XDG_CONFIG_HOME:-$HOME/.config}/projects.conf"
if [ -r "$config" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line#"${line%%[![:space:]]*}"}"
        [ -z "$line" ] && continue
        [ "${line:0:1}" = "#" ] && continue
        case "$line" in
            "~/"*) line="$HOME/${line#"~/"}" ;;
            "~") line="$HOME" ;;
        esac
        printf '%s\t%s\t%s\n' "$(basename "$line")" "$line" "path"
    done < "$config"
fi
