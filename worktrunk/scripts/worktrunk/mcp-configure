#!/usr/bin/env bash
# Configure MCP servers for a worktree.
# Usage: mcp-configure <worktree-path>
# Reads WT_ENABLED_MCPS (newline-separated server names) from the environment.
# Defaults to eng-delivery when unset (e.g. Linear integration).
#
# 1. Ensures .mcp.json exists in the worktree (copies from template if not)
# 2. Writes enabledMcpjsonServers / disabledMcpjsonServers to
#    .claude/settings.local.json so Claude connects only the selected servers

set -euo pipefail

wt_path="${1:-}"
[ -z "$wt_path" ] && exit 0

template="$HOME/.claude/mcp-servers.json"
[ -f "$template" ] || exit 0

if [ ! -f "$wt_path/.mcp.json" ]; then
    cp "$template" "$wt_path/.mcp.json"
fi

all_mcps=$(jq -r '.mcpServers | keys[]' "$wt_path/.mcp.json" 2>/dev/null) || exit 0

enabled="${WT_ENABLED_MCPS:-eng-delivery}"
enabled_json=$(printf '%s' "$enabled" | tr ' ' '\n' | jq -R 'select(length > 0)' | jq -s .)

enabled_set=" $enabled "
disabled=""
while IFS= read -r name; do
    case "$enabled_set" in
        *" $name "*) ;;
        *) disabled="${disabled:+$disabled\n}$name" ;;
    esac
done <<< "$all_mcps"
disabled_json=$(printf '%b' "$disabled" | jq -R 'select(length > 0)' | jq -s .)

settings="$wt_path/.claude/settings.local.json"
mkdir -p "$(dirname "$settings")"

if [ -f "$settings" ]; then
    tmp="${TMPDIR:-/tmp}/claude-settings.$$"
    jq --argjson enabled "$enabled_json" --argjson disabled "$disabled_json" \
        '.enabledMcpjsonServers = $enabled | .disabledMcpjsonServers = $disabled' \
        "$settings" > "$tmp" && mv "$tmp" "$settings"
else
    jq -n --argjson enabled "$enabled_json" --argjson disabled "$disabled_json" \
        '{enabledMcpjsonServers: $enabled, disabledMcpjsonServers: $disabled}' > "$settings"
fi
