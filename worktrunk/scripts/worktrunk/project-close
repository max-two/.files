#!/usr/bin/env bash
# Interactive worktree teardown. Tab closing is handled by worktrunk's
# post-remove hook, not by this script.

set -euo pipefail

[ -z "${ZELLIJ:-}" ] && echo "Not inside Zellij" && exit 1

script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")

# Filter to worktree entries only — repo entries are main checkouts of regular
# repos and can't be safely removed via `wt remove`. Since every row is a
# worktree, there's no type column — just an aligned name and path. `sep` is the
# ┃ project-list uses to join repo┃branch: 3 bytes but 1 display column, so
# byte-counting awk must discount it to keep the path column aligned.
sep=$(printf '\342\224\203')  # U+2503 ┃
list=$("$script_dir/project-list" | awk -F'\t' -v sep="$sep" '
function dispw(s,   t) { t = s; return length(s) - 2 * gsub(sep, "", t) }
function pad(s, w,   n) { n = w - dispw(s); return (n < 1) ? s : s sprintf("%*s", n, "") }
$3 == "worktree" {
    line[++count] = $0
    d = dispw($1); if (d > wn) wn = d
}
END {
    for (i = 1; i <= count; i++) {
        split(line[i], f, "\t")
        printf "%s  %s\t%s\n", pad(f[1], wn), f[2], f[2]
    }
}
')

[ -z "$list" ] && exit 0

# Default the fzf cursor to the current tab's worktree, if this tab is one.
# The keybind launches project-close as a floating pane, which inherits the
# focused pane's cwd (see config.kdl), so `git rev-parse --show-toplevel` from
# here resolves the worktree we're in. Match it against each row's path (the
# 2nd, tab-delimited field) and pre-position via fzf's `start` event — which
# needs `--sync` so the list is fully loaded before pos() runs. Not in a listed
# worktree (e.g. a main repo, or outside git) → no --bind, cursor stays on the
# first entry.
pos_bind=()
current_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -n "$current_root" ]; then
    n=$(printf '%s\n' "$list" | awk -F'\t' -v p="$current_root" '$2 == p { print NR; exit }')
    [ -n "$n" ] && pos_bind=(--sync --bind "start:pos($n)")
fi

selection=$(printf '%s\n' "$list" | fzf \
    --multi \
    --delimiter=$'\t' \
    --with-nth=1 \
    "${pos_bind[@]}" \
    --prompt='close> ' \
    --header='tab: toggle  enter: remove selected  esc: cancel')

[ -z "$selection" ] && exit 0

# Remove a single worktree. Pick a working dir for `wt remove` that is NOT the
# worktree being removed: if we pass -C the target, worktrunk auto-switches us
# out first (fires post-switch, spawns an unwanted tab). Instead, point -C at
# the bare repo dir (for bare-repo worktrees) or the main-repo dir (for
# regular-repo additional worktrees). Both work for any worktree of the repo,
# including the last one — no sibling needed.
# Returns non-zero if the worktree was left in place (failed or skipped).
remove_worktree() {
    local worktree_path="$1"
    local branch target_parent safe_dir common_dir key

    branch=$(git -C "$worktree_path" branch --show-current 2>/dev/null)
    target_parent=$(dirname "$worktree_path")

    if [ -d "$target_parent/.bare" ]; then
        safe_dir="$target_parent"
    else
        common_dir=$(git -C "$worktree_path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
        safe_dir="${common_dir%/.git}"
        safe_dir="${safe_dir%/.bare}"
    fi

    if wt -C "$safe_dir" remove --yes "$branch"; then
        return 0
    fi

    echo ""
    echo "Press [f] to force-remove '$branch' (--force --force-delete), any other key to skip."
    # Read from the tty, not stdin — stdin is the selection list the loop below
    # is iterating, so an unredirected read would swallow the next worktree.
    read -rn 1 key </dev/tty
    echo ""
    if [ "$key" = "f" ] || [ "$key" = "F" ]; then
        wt -C "$safe_dir" remove --yes --force --force-delete "$branch" && return 0
    fi

    return 1
}

failed=0
while IFS=$'\t' read -r _ worktree_path; do
    [ -z "$worktree_path" ] && continue
    remove_worktree "$worktree_path" || failed=1
done <<< "$selection"

if [ "$failed" = 1 ]; then
    echo ""
    echo "(some worktrees were left in place — press any key to close)"
    read -rn 1 </dev/tty
fi
