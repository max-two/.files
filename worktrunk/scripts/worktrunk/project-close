#!/usr/bin/env bash
# Interactive worktree teardown. Tab closing is handled by worktrunk's
# post-remove hook, not by this script.

set -euo pipefail

[ -z "${ZELLIJ:-}" ] && echo "Not inside Zellij" && exit 1

script_dir=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")

# Filter to worktree entries only — repo entries are main checkouts of
# regular repos and can't be safely removed via `wt remove`.
selection=$("$script_dir/project-list" | awk -F'\t' '
$3 == "worktree" { data[NR] = $0; if (length($1) > w1) w1 = length($1); if (length($2) > w2) w2 = length($2) }
END {
    for (i in data) {
        n = split(data[i], f, "\t")
        printf "%-*s  %-*s  %s\t%s\n", w1, f[1], w2, f[2], f[3], f[2]
    }
}
' | fzf \
    --multi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --prompt='close> ' \
    --header='tab: toggle  enter: remove selected  esc: cancel')

[ -z "$selection" ] && exit 0

# Remove a single worktree. Pick a working dir for `wt remove` that is NOT the
# worktree being removed: if we pass -C the target, worktrunk auto-switches us
# out first (fires post-switch, spawns an unwanted tab). Instead, point -C at
# the bare repo dir (for bare-repo worktrees) or the main-repo dir (for
# regular-repo additional worktrees). Both work for any worktree of the repo,
# including the last one — no sibling needed.
# Returns non-zero if the worktree was left in place (failed or skipped).
remove_worktree() {
    local worktree_path="$1"
    local branch target_parent safe_dir common_dir key

    branch=$(git -C "$worktree_path" branch --show-current 2>/dev/null)
    target_parent=$(dirname "$worktree_path")

    if [ -d "$target_parent/.bare" ]; then
        safe_dir="$target_parent"
    else
        common_dir=$(git -C "$worktree_path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
        safe_dir="${common_dir%/.git}"
        safe_dir="${safe_dir%/.bare}"
    fi

    if wt -C "$safe_dir" remove --yes "$branch"; then
        return 0
    fi

    echo ""
    echo "Press [f] to force-remove '$branch' (--force --force-delete), any other key to skip."
    # Read from the tty, not stdin — stdin is the selection list the loop below
    # is iterating, so an unredirected read would swallow the next worktree.
    read -rn 1 key </dev/tty
    echo ""
    if [ "$key" = "f" ] || [ "$key" = "F" ]; then
        wt -C "$safe_dir" remove --yes --force --force-delete "$branch" && return 0
    fi

    return 1
}

failed=0
while IFS=$'\t' read -r _ worktree_path; do
    [ -z "$worktree_path" ] && continue
    remove_worktree "$worktree_path" || failed=1
done <<< "$selection"

if [ "$failed" = 1 ]; then
    echo ""
    echo "(some worktrees were left in place — press any key to close)"
    read -rn 1 </dev/tty
fi
