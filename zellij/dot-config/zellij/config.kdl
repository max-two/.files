// Zellij configuration
// Full default config: zellij setup --dump-config
// Docs: https://zellij.dev/documentation/

// Use Ghostty's native scrollback instead of zellij's
scrollback_editor "none"

// Plugin aliases. The built-in aliases below are reproduced verbatim from
// `zellij setup --dump-config`: a user `plugins` block does NOT merge with the
// defaults, so omitting them would break tab-bar/compact-bar/session-manager/etc.
// The `zjstatus` alias adds a custom status bar and carries its full config here
// (single source of truth) so both layouts can reference it by the bare name.
// Editing aliases requires a session restart to take effect.
plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    compact-bar location="zellij:compact-bar"
    session-manager location="zellij:session-manager"
    welcome-screen location="zellij:session-manager" {
        welcome_screen true
    }
    filepicker location="zellij:strider" {
        cwd "/"
    }
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
    about location="zellij:about"

    // Custom status bar (dj95/zjstatus), pinned to v0.23.0 — built against
    // zellij-tile 0.44.1, matching this machine's zellij 0.44.x. Active tab =
    // green-filled capsule with rounded ends (echoing the rounded pane borders);
    // inactive = dim grey text. Tabs left-aligned like the old compact-bar.
    // Everforest colours: bg #1e2326, green #a7c080, dim grey #7a8478.
    zjstatus location="https://github.com/dj95/zjstatus/releases/download/v0.23.0/zjstatus.wasm" {
        // Left pad (1 col) so bar content is inset like the rounded pane borders.
        format_left  "#[bg=#1e2326] {mode}{tabs}"
        format_right "{command_battery}{datetime}"
        format_space "#[bg=#1e2326]"

        // Tabs: active = green-filled rounded pill, inactive = dim grey text (no index).
        tab_normal    "#[fg=#7a8478,bg=#1e2326] {name} "
        tab_active    "#[fg=#a7c080,bg=#1e2326]#[fg=#1e2326,bg=#a7c080,bold]{name}#[fg=#a7c080,bg=#1e2326]"
        tab_separator "#[bg=#1e2326] "

        // Mode indicator: SQUARE block (distinct from the rounded tab pills); NORMAL is
        // grey, not the active green. Labels centred in an 8-col field => constant width.
        mode_normal        "#[fg=#1e2326,bg=#7a8478,bold] NORMAL #[bg=#1e2326]  "
        mode_locked        "#[fg=#1e2326,bg=#e67e80,bold] LOCKED #[bg=#1e2326]  "
        mode_resize        "#[fg=#1e2326,bg=#e69875,bold] RESIZE #[bg=#1e2326]  "
        mode_pane          "#[fg=#1e2326,bg=#7fbbb3,bold]  PANE  #[bg=#1e2326]  "
        mode_tab           "#[fg=#1e2326,bg=#7fbbb3,bold]  TAB   #[bg=#1e2326]  "
        mode_scroll        "#[fg=#1e2326,bg=#dbbc7f,bold] SCROLL #[bg=#1e2326]  "
        mode_search        "#[fg=#1e2326,bg=#dbbc7f,bold] SEARCH #[bg=#1e2326]  "
        mode_enter_search  "#[fg=#1e2326,bg=#dbbc7f,bold] SEARCH #[bg=#1e2326]  "
        mode_rename_tab    "#[fg=#1e2326,bg=#d699b6,bold] RENAME #[bg=#1e2326]  "
        mode_rename_pane   "#[fg=#1e2326,bg=#d699b6,bold] RENAME #[bg=#1e2326]  "
        mode_session       "#[fg=#1e2326,bg=#d699b6,bold]SESSION #[bg=#1e2326]  "
        mode_move          "#[fg=#1e2326,bg=#e69875,bold]  MOVE  #[bg=#1e2326]  "
        mode_tmux          "#[fg=#1e2326,bg=#e69875,bold]  TMUX  #[bg=#1e2326]  "
        mode_prompt        "#[fg=#1e2326,bg=#dbbc7f,bold] PROMPT #[bg=#1e2326]  "

        // Clock, far right. WASM cannot read the system TZ, so it is pinned.
        datetime          "#[fg=#7a8478,bg=#1e2326] {format} "
        datetime_format   "%-I:%M%P"
        datetime_timezone "America/New_York"

        // Battery: script emits a Nerd Font glyph + %, self-coloured by charge range
        // (green/yellow/red, blue when charging). rendermode "dynamic" renders its #[..].
        command_battery_command    "/Users/max.mckinley/scripts/battery/battery-status"
        command_battery_format     "{stdout}"
        command_battery_interval   "60"
        command_battery_rendermode "dynamic"
    }
}

// Background notification plugin (zellij-attention) — badges this tab when Claude
// Code wants attention. Driven by Claude Code hooks in ~/.claude/settings.json via
// `zellij pipe`. The plugin exposes only two slots, "completed" and "waiting", which
// we map to:
//   completed_icon "✓" ← Claude is idle / your turn         (Notification:idle_prompt)
//   waiting_icon   "●" ← Claude needs a permission decision (Notification:permission_prompt)
// Icons auto-clear when you focus the pane. Swap glyphs freely (e.g. ✅ / 🔴 for color).
// Loaded from a pinned release; bump the version in the URL to update.
load_plugins {
    "https://github.com/KiryuuLight/zellij-attention/releases/download/v0.3.1/zellij-attention.wasm" {
        enabled "true"
        completed_icon "✓"
        waiting_icon "●"
    }

    // Built-in click-to-open (zellij:link): hover a file path in any pane to
    // reveal it (italic + underline + "Open" tooltip), then alt+click to open
    // it in $EDITOR (hx) as a floating pane, jumping to :line. Directories open
    // the filepicker instead. Must be listed explicitly: a user `load_plugins`
    // block REPLACES the default one (background_plugins are not merged across
    // configs), which would otherwise silently drop this built-in. Loads on
    // session start and prompts once for filesystem + app-state permissions.
    // If paths don't highlight on hover, try adding `advanced_mouse_actions true`.
    "zellij:link"
}

// Keybinds
keybinds {
    shared_except "locked" {
        // Pane focus with Ctrl + hjkl
        bind "Ctrl h" { MoveFocus "Left"; }
        bind "Ctrl j" { MoveFocus "Down"; }
        bind "Ctrl k" { MoveFocus "Up"; }
        bind "Ctrl l" { MoveFocus "Right"; }

        // Tab navigation with Alt + h/l
        bind "Alt h" { GoToPreviousTab; }
        bind "Alt l" { GoToNextTab; }

        // Toggle fullscreen for the focused pane
        bind "Ctrl f" { ToggleFocusFullscreen; }

        bind "Ctrl /" {
            Run "navi" "--print" {
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        bind "Alt o" {
            Run "project-open" {
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        bind "Alt w" {
            Run "project-new" {
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        // Restart Claude in the current pane, resuming the session (--continue).
        // in_place suspends the old pane and execs the new Claude in its place;
        // project-refresh first sweeps stale suspended panes so their
        // zellij-attention icons don't get stuck (see the script header).
        bind "Alt z" {
            Run "project-refresh" {
                in_place true
                close_on_exit true
            }
        }
        bind "Alt x" {
            Run "project-close" {
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        // revdiff: per-tab floating review of the focused pane's repo — "summon"
        // semantics. First press opens revdiff for that worktree; re-press REVEALS
        // the same review instead of stacking a second pane (dismiss with Alt+f, or
        // quit revdiff with q to start a fresh review). Dedup lives in
        // ~/scripts/revdiff/revdiff-summon via zj-summon, which matches on
        // terminal_command — revdiff sets its own OSC title ("rd: <ref>"), so title
        // matching is unreliable. Still bare `revdiff` (no smart ref-detection —
        // that's the /revdiff skill). On quit, annotations auto-save to
        // ~/.config/revdiff/history/<repo>/; then tell Claude "apply my latest
        // revdiff annotations" to ingest them.
        bind "Alt r" {
            Run "revdiff-summon" {
                name "revdiff"
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        // Storybook (rosetta pxds) for the CURRENT worktree, per tab. Opens as a
        // STACKED pane joining the tab's right-side helix/terminal stack (MoveFocus
        // "Right" biases focus onto that stack first), so it lives OFF the floating
        // layer. The script resolves the focused pane's cwd to its git worktree and
        // runs that worktree's pxds (no-op outside rosetta); first press starts
        // Storybook on the first free port from 6006 (it opens the browser), later
        // presses focus the existing pane. See ~/scripts/storybook/storybook-pxds.
        bind "Alt s" {
            MoveFocus "Right"
            Run "storybook-pxds" {
                name "storybook"
                stacked true
                close_on_exit true
            }
        }
        // Scratchpad note for the CURRENT worktree, per tab — "summon" semantics.
        // Opens Helix on <worktree>/notes.local.md (gitignored via the global core
        // excludes, auto-deleted with the worktree on `wt merge`) in a floating
        // pane; re-press reveals that tab's existing note buffer. Dismiss by
        // quitting Helix (:wq) or hiding the floating layer (Alt+f). Falls back to
        // ~/notes.local.md outside a repo. The dispatcher runs floating (NOT
        // in_place — that suspended/replaced the focused work pane); see
        // ~/scripts/notes/notes.
        bind "Alt n" {
            Run "notes" {
                name "notes"
                floating true
                x "17%"
                y "17%"
                width "66%"
                height "66%"
                close_on_exit true
            }
        }
        bind "Ctrl Shift x" {
            Run "zellij" "kill-all-sessions" "--yes" {
                close_on_exit true
            }
        }
        bind "Ctrl Shift r" {
            Run "touch" "/Users/max.mckinley/.config/zellij/config.kdl" {
                close_on_exit true
            }
        }
    }
}

// Theme — matches Ghostty's "Everforest Dark Hard"
theme "everforest-dark"

themes {
    everforest-dark {
        fg 211 198 170      // #d3c6aa
        bg 30 35 38         // #1e2326
        black 122 132 120   // #7a8478
        white 242 239 223   // #f2efdf
        red 230 126 128     // #e67e80
        green 167 192 128   // #a7c080
        yellow 219 188 127  // #dbbc7f
        blue 127 187 179    // #7fbbb3
        magenta 214 153 182 // #d699b6
        orange 230 152 117  // #e69875
        cyan 131 192 146    // #83c092
    }
}

// Pane frame appearance
ui {
    pane_frames {
        rounded_corners true   // soften the frame corners
        hide_session_name true // drop the session name from the frame ribbon
    }
}

show_startup_tips false
