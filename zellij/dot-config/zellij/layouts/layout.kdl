// Worktree/Claude tab layout (opened by worktrunk's zellij-tab-open). Uses the
// custom `zjstatus` status bar (alias + config defined in config.kdl) to match
// the default layout.
layout {
    tab {
        pane split_direction="vertical" {
            pane command="claude" size="50%" focus=true close_on_exit=true
            pane stacked=true size="50%" {
                pane command="hx" expanded=true close_on_exit=true {
                    args "README.md"
                }
                pane name="terminal"
            }
        }

        pane size=1 borderless=true {
            plugin location="zjstatus"
        }
    }
}
