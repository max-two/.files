#!/usr/bin/env bash
# Summon a scratchpad note for the CURRENT worktree in a per-tab floating Zellij
# pane, opened in Helix. The summon-or-reveal mechanics live in zj-summon; this
# script only resolves which note to edit.
#
# Worktree-aware: a keybind `Run { floating true }` pane inherits the focused
# pane's cwd, so our cwd is the cwd of the pane you pressed Alt+n from. We
# resolve that to its git worktree root and edit THAT worktree's notes.local.md,
# falling back to ~/notes.local.md outside any repo. The note is gitignored via
# the global core excludes (*.local.*) and lives in-worktree, so it's cleaned up
# with the worktree on `wt merge`.
#
# Bound to Alt+n in zellij/dot-config/zellij/config.kdl.

set -euo pipefail

[ -z "${ZELLIJ:-}" ] && exit 0

root=$(git rev-parse --show-toplevel 2>/dev/null) || root="$HOME"
exec "$HOME/scripts/zellij/zj-summon" "$root" -- hx "$root/notes.local.md"
