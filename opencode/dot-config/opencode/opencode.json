{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openai/gpt-5.4-mini",
  "model": "openai/gpt-5.3-codex",
  "permission": {
    "websearch": "allow"
  },
  "formatter": {
    "oxfmt": {
      "environment": {
        "OPENCODE_EXPERIMENTAL_OXFMT": "true"
      }
    }
  },
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    },
    "pyright": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "general": {
      "description": "File search, simple edits, mechanical work invoked by build",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "ask",
        "bash": "ask",
        "task": "ask"
      }
    },
    "explore": {
      "description": "Read-only codebase exploration with large context",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    },
    "scout": {
      "description": "Read-only external docs and dependency research",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "repo_clone": "allow",
        "repo_overview": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    }
  }
}
