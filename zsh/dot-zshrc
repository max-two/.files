# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Zellij
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

if [[ -z "$ZELLIJ" ]]; then
  zellij --layout default attach -c
  exit
fi

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Prompt
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Instant Prompt (Needs to stay at top of this file)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# P10K
typeset -gix P9K_SSH=0        # Skip SSH detection (not needed on local machine)
typeset -gx _P9K_SSH_TTY=$TTY
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Exports
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Homebrew shell env: sets HOMEBREW_PREFIX/CELLAR/REPOSITORY, INFOPATH, and the brew
# completions fpath. PATH itself is already built in ~/.zsh_path.zsh (sourced by
# .zshenv/.zprofile), so brew shellenv's PATH line is a no-op here (it won't re-prepend
# an already-present /opt/homebrew/bin) — this is purely for the env vars the completions
# + antidote lines below rely on ($HOMEBREW_PREFIX). Guarded so the ~60ms call runs once
# per process tree; kept here (not .zshenv) so it doesn't cost non-interactive shells.
if [[ -z "$HOMEBREW_PREFIX" && -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
export HOMEBREW_NO_ANALYTICS=1 # Turn off analytics
export HOMEBREW_NO_ENV_HINTS=1 # Turn off hints

# Bat
export MANPAGER="sh -c 'col -bx | bat -l man -p'" # Make man pages colorful

# Default editor
export EDITOR="hx"

# Dev-server "open in editor" (Storybook/Vite/webpack) -> Helix in a new Zellij
# tab. The `launch-editor` package these use scans for a running GUI editor
# (e.g. VS Code) before it ever checks $EDITOR; only these jump that queue.
export LAUNCH_EDITOR="$HOME/scripts/helix/hx-open"
export REACT_EDITOR="$LAUNCH_EDITOR"

# LSP
export ENABLE_LSP_TOOL=1

# OpenCode
export OPENCODE_ENABLE_EXA=1

# Zoxide DB cap (default 10000 — too low for priming many worktrees of a large repo)
export _ZO_MAXAGE=100000


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Aliases
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
alias rc='source $HOME/.zshrc'
alias zshrc='hx $HOME/.zshrc'
alias h='hx'
alias g='git'
alias ls='eza --color --icons --all --group-directories-first'
alias ll='eza --long --header --time-style=relative --no-filesize --tree --level=2 --color --icons --all --group-directories-first'
alias z='zed'
alias zi='zed $(fzf -m --preview="bat --color=always {}")' # Fuzzy open files in zed
alias cat='bat'
alias brew-up='brew update && brew upgrade --cask --greedy obsidian && brew upgrade'
alias ...='popd'
alias claude-logs='tail -f ~/.claude/logs/session_$(cat ~/.claude/logs/.current_session).log'
alias -g -- --help='--help 2>&1 | bat --language=help --style=plain' # Colorful help

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Keybindings
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Peruse history with the context of what's already been typed
bindkey "^[[A" history-search-backward
bindkey "^[[B" history-search-forward


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# ZSH Configuration
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# cd
setopt autocd # cd without typing cd
setopt auto_pushd # Put cd history onto stack
setopt pushd_ignore_dups # Ignore duplicates for cd stack
setopt pushd_silent # Don't print stack after popd

# History
HISTSIZE=9999
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_find_no_dups


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Helpers
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

source $HOME/.zsh_cached_eval.zsh


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Completions
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}' # Case insensitive completions
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}" # Color completions
zstyle ':completion:*:git-checkout:*' sort false # Disable sort when completing `git checkout`
zstyle ':completion:*' menu no # Lets fzf capture unambiguous prefix
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 -a --color=always $realpath' # Show fzf directory previews for cd
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 -a --color=always $realpath' # Show fzf directory previews for zoxide

# Brewfile
brew_completion=$HOMEBREW_PREFIX/share/zsh/zsh-site-functions
if [ -d "$brew_completion" ];then
  fpath=($brew_completion $fpath)
fi

# Initialize completions (full rebuild once per day, skip security check otherwise)
autoload -Uz compinit
() {
  if [[ $# -gt 0 ]]; then compinit; else compinit -C; fi
} ~/.zcompdump(N.mh+24)

# fnm
if command -v fnm >/dev/null 2>&1; then
  _cached_eval fnm-completions fnm completions --shell zsh
fi


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Antidote
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

source $HOMEBREW_PREFIX/opt/antidote/share/antidote/antidote.zsh
antidote load


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Integrations
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# fzf
_cached_eval fzf fzf --zsh

# direnv
_cached_eval direnv direnv hook zsh

# fnm
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --shell zsh --use-on-cd --version-file-strategy=recursive --resolve-engines=false --log-level=quiet)"
fi



# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Functions
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# Auto ls after changing directory
function chpwd() {
    [[ -o interactive ]] && ls
}

# Colored git diff with bat
gdiff() {
    git diff --name-only --relative --diff-filter=d | xargs bat --diff
}


# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Local
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

[[ -f $HOME/.localrc ]] && source $HOME/.localrc

# worktrunk (before zoxide — needs shell wrapper for wt switch to cd)
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# zoxide (must be last — overrides cd command and chpwd hook).
# Both the init and the cd() override below are guarded to interactive shells.
# The override calls zoxide's __zoxide_z, so defining it in a non-interactive
# shell (Claude Code's Bash tool, Zellij command panes, `zsh -c` scripts that
# source this file) would leave a cd() that calls an undefined __zoxide_z and
# fails with exit 127. Non-interactive shells keep the plain builtin cd.
if [[ -o interactive ]]; then
  _cached_eval zoxide zoxide init --cmd cd zsh

  # Bias zoxide queries toward the current git worktree by injecting the
  # worktree's basename as a leading keyword. Combined with the post-start
  # `zoxide-prime` hook in worktrunk config, this makes `cd src` from inside a
  # fresh worktree land at that worktree's `src` instead of master's.
  # Must come after zoxide init (it overrides the cd function zoxide created).
  cd() {
    if [ $# -eq 0 ] || [ -d "$1" ] || [[ "$1" == /* || "$1" == ./* || "$1" == ../* || "$1" == ~* || "$1" == - || "$1" == -- ]]; then
      __zoxide_z "$@"
      return
    fi

    local toplevel
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null)
    if [ -n "$toplevel" ]; then
      __zoxide_z "$(basename "$toplevel")" "$@" 2>/dev/null && return
    fi
    __zoxide_z "$@"
  }
fi

# Vite+ bin (https://viteplus.dev)
. "$HOME/.vite-plus/env"
