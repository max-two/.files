# Path additions that should be available to all zsh invocations
# (including non-interactive, e.g. Zellij command panes, Claude Code agents)
typeset -U path
path=("$HOME/.local/bin" "$HOME/scripts" "$HOME"/scripts/*(N-/) $path)
export PATH
# fnm's default Node (yarn, node, npm, tsc, etc.) — follows `fnm default`
export PATH="$HOME/.local/share/fnm/aliases/default/bin:$PATH"

# Point Zellij at the real config path. The stow symlink breaks its
# filesystem watcher, so edits to config.kdl don't auto-reload.
# See zellij-org/zellij#3992.
export ZELLIJ_CONFIG_FILE="$HOME/code/.files/zellij/dot-config/zellij/config.kdl"

# Worktrunk: load machine-local overrides (per-repo hooks for private work repos) from
# an untracked file, keeping private repo names out of this public dotfiles repo. The
# file is optional — worktrunk ignores it if absent (e.g. on machines without it).
export WORKTRUNK_SYSTEM_CONFIG_PATH="$HOME/.config/worktrunk/local.toml"

# Vite+ bin (https://viteplus.dev)
. "$HOME/.vite-plus/env"

# Machine-local env-layer overrides (e.g. work-repo registry tokens) — untracked,
# optional, parallels ~/.localrc. Keeps machine-specific config out of these dotfiles.
[[ -f $HOME/.localenv ]] && source $HOME/.localenv
