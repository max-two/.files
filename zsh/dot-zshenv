# PATH + Homebrew: single source of truth in ~/.zsh_path.zsh, sourced here so ALL
# zsh invocations — including non-interactive ones (Zellij command panes, scripts,
# AI-agent shells) — get the full PATH, and again from .zprofile to re-assert order
# after macOS path_helper (see that file). Keep this the ONLY place PATH is built.
source "$HOME/.zsh_path.zsh"

# Point Zellij at the real config path. The stow symlink breaks its
# filesystem watcher, so edits to config.kdl don't auto-reload.
# See zellij-org/zellij#3992. Guarded: if the repo isn't at this exact path
# (fresh clone elsewhere, or not yet stowed), leave the var unset so zellij
# falls back to its default discovery (~/.config/zellij/config.kdl) instead of
# failing to start — a dead ZELLIJ_CONFIG_FILE makes `zellij` exit non-zero,
# which the autostart in .zshrc would turn into a closed terminal.
_zj_cfg="$HOME/code/.files/zellij/dot-config/zellij/config.kdl"
[[ -f "$_zj_cfg" ]] && export ZELLIJ_CONFIG_FILE="$_zj_cfg"
unset _zj_cfg

# Vite+ bin (https://viteplus.dev). Guarded so shells on a machine without
# Vite+ installed don't error on every invocation (this runs for ALL zsh).
# Re-sourced in .zshrc after compinit to register completions — see there.
[[ -f "$HOME/.vite-plus/env" ]] && . "$HOME/.vite-plus/env"

# Machine-local env-layer overrides (e.g. work-repo registry tokens) — untracked,
# optional, parallels ~/.localrc. Keeps machine-specific config out of these dotfiles.
[[ -f $HOME/.localenv ]] && source $HOME/.localenv
