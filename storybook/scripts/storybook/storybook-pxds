#!/usr/bin/env bash
# Summon the rosetta pxds Storybook for the CURRENT worktree in a per-tab
# floating Zellij pane. The summon-or-reveal mechanics live in zj-summon; this
# script resolves the worktree, bails unless it's a rosetta pxds checkout, and
# picks a free port.
#
# Worktree-aware: our cwd is the focused pane's cwd (inherited by the keybind's
# floating Run). We resolve its git worktree and run Storybook from that
# worktree's packages/pxds -- a no-op unless that package is @healthbyro/pxds
# (i.e. nothing outside rosetta, or outside any git repo). rosetta is a Vite+
# workspace, so Storybook runs via `vp exec` (vp is on the non-interactive PATH
# via ~/.zshenv; pnpm is not).
#
# Bound to Alt+s in zellij/dot-config/zellij/config.kdl.

set -euo pipefail

[ -z "${ZELLIJ:-}" ] && exit 0

root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
pxds="$root/packages/pxds"
[ -f "$pxds/package.json" ] || exit 0
[ "$(jq -r '.name // empty' "$pxds/package.json" 2>/dev/null)" = "@healthbyro/pxds" ] || exit 0

# First free port from 6006 up -> Storybook won't prompt, so it opens the browser.
port=6006
while nc -z 127.0.0.1 "$port" 2>/dev/null; do port=$((port + 1)); done

exec "$HOME/scripts/zellij/zj-summon" storybook "$pxds" -- zsh -c "vp exec storybook dev -p $port"
