[push]
	autoSetupRemote = true

[color]
    ui = auto

[diff]
    external = difft

[alias]
    ad = add --all
    cm = commit -m
    sw = switch
	cb = switch -c
    db = branch -d
    st = stash
    sh = push
    ll = pull
    st = status
    lg = -c diff.external=difft log -p --ext-diff
	rs = restore
	unstage = restore --staged
    undo = reset --soft HEAD~1
    shw = -c diff.external=difft show --ext-diff
    mm = "!git stash push -u && git fetch origin master && git merge origin/master"
    nb = "!git switch master && git pull && git switch -c"
	nuke = "!git restore --staged . && git restore . && git clean -fd"
    clean-branches = "!git branch -vv | awk '/\\[.*gone]/{print $1}' | xargs -r git branch -D"
	
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[fetch]
	prune = true
